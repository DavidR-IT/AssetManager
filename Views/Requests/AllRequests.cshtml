@model IEnumerable<AssetRequest>
@{
    ViewData["Title"] = "All Requests";
}
<div class="container mt-4">
    <h2>All Asset Requests</h2>
    <p class="text-muted">Complete history of all asset requests in the system</p>
    <hr />

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> No requests found in the system.
        </div>
    }
    else
    {
        <!-- Filter buttons -->
        <div class="btn-group mb-3" role="group">
            <button type="button" class="btn btn-outline-secondary active" onclick="filterRequests(event, 'all')">All</button>
            <button type="button" class="btn btn-outline-warning" onclick="filterRequests(event, 'Pending')">Pending</button>
            <button type="button" class="btn btn-outline-success" onclick="filterRequests(event, 'Approved')">Approved</button>
            <button type="button" class="btn btn-outline-danger" onclick="filterRequests(event, 'Rejected')">Rejected</button>
            <button type="button" class="btn btn-outline-secondary" onclick="filterRequests(event, 'Cancelled')">Cancelled</button>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover" id="requestsTable">
                <thead class="table-dark">
                    <tr>
                        <th>Request ID</th>
                        <th>Asset(s)</th>
                        <th>Category</th>
                        <th>Brand/Model</th>
                        <th>Requested By</th>
                        <th>Request Type</th>
                        <th>Request Date</th>
                        <th>Status</th>
                        <th>Approved/Rejected By</th>
                        <th>Approval Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var request in Model)
                    {
                        <tr data-status="@request.Status">
                            <td>@request.Id</td>

                            @* Asset(s) Column - Show badge for multi-asset, tag for single *@
                            <td>
                                @if (request.RequestedAssets != null && request.RequestedAssets.Any())
                                {
                                    <span class="badge bg-primary">
                                        <i class="fas fa-layer-group"></i> @request.RequestedAssets.Count asset(s)
                                    </span>
                                }
                                else
                                {
                                    @(request.Asset?.AssetTag ?? "N/A")
                                }
                            </td>

                            @* Category Column *@
                            <td>
                                @if (request.RequestedAssets != null && request.RequestedAssets.Any())
                                {
                                    <span class="text-muted small">Multiple</span>
                                }
                                else
                                {
                                    @(request.Asset?.Category ?? "N/A")
                                }
                            </td>

                            @* Brand/Model Column *@
                            <td>
                                @if (request.RequestedAssets != null && request.RequestedAssets.Any())
                                {
                                    <span class="text-muted small">Various</span>
                                }
                                else
                                {
                                    <span>@request.Asset?.Brand @request.Asset?.Model</span>
                                }
                            </td>

                            <td>@request.RequestedBy</td>
                            <td>
                                <span class="badge bg-@(request.RequestType == RequestTypes.Issue ? "primary" : request.RequestType == RequestTypes.Request ? "success" : request.RequestType == RequestTypes.Return ? "warning" : "info")">
                                    @request.RequestType
                                </span>
                            </td>
                            <td>@request.RequestDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <span class="badge bg-@GetStatusColor(request.Status)">@request.Status</span>
                            </td>
                            <td>@(request.ApprovedBy ?? "N/A")</td>
                            <td>@(request.ApprovalDate?.ToString("yyyy-MM-dd HH:mm") ?? "N/A")</td>
                            <td>
                                <a class="btn btn-sm btn-info" asp-action="Details" asp-route-id="@request.Id">
                                    <i class="fas fa-eye"></i> Details
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-3">
            <p class="text-muted">
                <strong>Pending:</strong> @Model.Count(r => r.Status == RequestStatuses.Pending) |
                <strong>Approved:</strong> @Model.Count(r => r.Status == RequestStatuses.Approved) |
                <strong>Rejected:</strong> @Model.Count(r => r.Status == RequestStatuses.Rejected) |
                <strong>Cancelled:</strong> @Model.Count(r => r.Status == RequestStatuses.Cancelled)
            </p>
        </div>
    }

    <div class="mt-3">
        <a class="btn btn-secondary" asp-action="Index">
            <i class="fas fa-arrow-left"></i> Back to Pending Requests
        </a>
    </div>
</div>

@section Scripts {
    <script>
        function filterRequests(event, status) {
            const rows = document.querySelectorAll('#requestsTable tbody tr');
            const buttons = document.querySelectorAll('.btn-group button');

            // Update active button
            buttons.forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');

            // Filter rows
            rows.forEach(row => {
                if (status === 'all' || row.getAttribute('data-status') === status) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }
    </script>
}

@functions {
    private string GetStatusColor(string status)
    {
        return status switch
        {
            RequestStatuses.Pending => "warning",
            RequestStatuses.Approved => "success",
            RequestStatuses.Rejected => "danger",
            RequestStatuses.Cancelled => "secondary",
            _ => "light"
        };
    }
}
