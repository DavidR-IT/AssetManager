@using System.Security.Claims
@model Asset
@{
    ViewData["Title"] = "Asset Details";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Asset Details</h2>
        <div>
            @if (User.IsInRole("Admin"))
            {
                <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">
                    <i class="fas fa-edit"></i> Edit
                </a>
            }
            <a class="btn btn-secondary" asp-action="Index">
                <i class="fas fa-arrow-left"></i> Back to List
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">@Model.AssetTag</h4>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <dl class="row">
                        <dt class="col-sm-4">Asset Tag:</dt>
                        <dd class="col-sm-8">@Model.AssetTag</dd>

                        <dt class="col-sm-4">Category:</dt>
                        <dd class="col-sm-8">@Model.Category</dd>

                        <dt class="col-sm-4">Brand:</dt>
                        <dd class="col-sm-8">@Model.Brand</dd>

                        <dt class="col-sm-4">Model:</dt>
                        <dd class="col-sm-8">@Model.Model</dd>

                        <dt class="col-sm-4">Serial Number:</dt>
                        <dd class="col-sm-8">@(Model.SerialNumber ?? "N/A")</dd>

                        <dt class="col-sm-4">Purchase Date:</dt>
                        <dd class="col-sm-8">@(Model.PurchaseDate?.ToShortDateString() ?? "N/A")</dd>
                    </dl>
                </div>

                <div class="col-md-6">
                    <dl class="row">
                        <dt class="col-sm-4">Purchase Price:</dt>
                        <dd class="col-sm-8">@(Model.PurchasePrice.HasValue ? $"${Model.PurchasePrice.Value:N2}" : "N/A")</dd>

                        <dt class="col-sm-4">Location:</dt>
                        <dd class="col-sm-8">@Model.Location</dd>

                        <dt class="col-sm-4">Status:</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-@GetStatusColor(Model.Status)">@Model.Status</span>
                        </dd>

                        <dt class="col-sm-4">Assigned To:</dt>
                        <dd class="col-sm-8">@(Model.AssignedTo ?? "Not Assigned")</dd>

                        <dt class="col-sm-4">Assigned Date:</dt>
                        <dd class="col-sm-8">@(Model.AssignedDate?.ToShortDateString() ?? "N/A")</dd>
                    </dl>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <hr />
                <div class="row">
                    <div class="col-12">
                        <h5>Notes</h5>
                        <p>@Model.Notes</p>
                    </div>
                </div>
            }

            @* QR CODE SECTION - Visible to ALL authenticated users *@
            <hr />
            <div class="row">
                <div class="col-12">
                    <h5>Asset QR Code</h5>
                    <p class="text-muted">Scan this QR code to quickly access this asset's information</p>
                    <div class="text-center my-3">
                        <img src="@Url.Action("GenerateQRCode", "Assets", new { id = Model.Id })"
                             alt="QR Code for @Model.AssetTag"
                             class="img-fluid border p-2"
                             style="max-width: 300px;" />
                    </div>
                    @if (User.IsInRole("Admin") || User.IsInRole("Issuer"))
                    {
                        <div class="text-center">
                            <a class="btn btn-success"
                               asp-controller="Assets"
                               asp-action="DownloadQRCode"
                               asp-route-id="@Model.Id">
                                <i class="fas fa-download"></i> Download QR Code for Printing
                            </a>
                        </div>
                    }
                </div>
            </div>

            @* Message if accessed via QR code *@
            @if (ViewBag.AccessedViaQR == true)
            {
                <div class="alert alert-info mt-3" role="alert">
                    <i class="fas fa-qrcode"></i> You accessed this asset by scanning its QR code!
                </div>
            }
        </div>
    </div>

    @* Action buttons based on user role *@
    <div class="mt-3">
        @if (User.IsInRole("Issuer"))
        {
            @if (Model.Status == AssetStatus.Ready)
            {
                <a class="btn btn-success"
                   asp-controller="Assets"
                   asp-action="RequestAsset"
                   asp-route-id="@Model.Id">
                    <i class="fas fa-hand-paper"></i> Request Asset
                </a>
            }
            @if (Model.Status == AssetStatus.Assigned)
            {
                <a class="btn btn-warning" asp-controller="Assets" asp-action="ReturnAsset" asp-route-id="@Model.Id">
                    <i class="fas fa-undo"></i> Return Asset
                </a>
            }
        }

        @if (User.IsInRole("Admin"))
        {
            
            <a class="btn btn-danger" asp-action="Delete" asp-route-id="@Model.Id" onclick="return confirm('Are you sure you want to delete this asset?');">
                <i class="fas fa-trash"></i> Delete
            </a>
        }
    </div>
</div>

@functions {
    private string GetStatusColor(AssetStatus status)
    {
        return status switch
        {
            AssetStatus.Ready => "success",
            AssetStatus.Pending => "warning",
            AssetStatus.Assigned => "info",
            AssetStatus.Maintenance => "secondary",
            AssetStatus.Retired => "danger",
            _ => "light"
        };
    }
}
