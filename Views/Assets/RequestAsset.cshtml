@{
    ViewData["Title"] = "Request Asset(s)";
    var singleAssetId = ViewBag.SingleAssetId as int?;
    var availableAssets = ViewBag.AvailableAssets as List<Asset>;
    Asset? singleAsset = null;
    
    if (singleAssetId.HasValue && availableAssets != null)
    {
        singleAsset = availableAssets.FirstOrDefault(a => a.Id == singleAssetId.Value);
    }
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-file-signature"></i> 
                        Request Asset@(singleAsset != null ? "" : "s")
                    </h4>
                </div>
                <div class="card-body">
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-triangle"></i> @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (availableAssets == null || !availableAssets.Any())
                    {
                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-circle"></i> No assets are currently available for request.
                        </div>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Back to Assets
                        </a>
                    }
                    else
                    {
                        <!-- Request Form -->
                        <form asp-action="RequestAssetConfirmed" method="post" id="requestForm">
                            @Html.AntiForgeryToken()

                            <!-- Asset Selection -->
                            <div class="mb-4">
                                <label class="form-label">
                                    <i class="fas fa-laptop"></i> Select Asset(s) <span class="text-danger">*</span>
                                </label>
                                
                                @if (singleAsset != null)
                                {
                                    <!-- Single asset pre-selected -->
                                    <input type="hidden" name="assetIds" value="@singleAsset.Id" />
                                    <div class="card bg-light">
                                        <div class="card-body">
                                            <div class="row">
                                                <div class="col-md-6">
                                                    <p><strong>Asset Tag:</strong> @singleAsset.AssetTag</p>
                                                    <p><strong>Category:</strong> @singleAsset.Category</p>
                                                    <p><strong>Brand:</strong> @singleAsset.Brand</p>
                                                </div>
                                                <div class="col-md-6">
                                                    <p><strong>Model:</strong> @singleAsset.Model</p>
                                                    <p><strong>Serial Number:</strong> @(singleAsset.SerialNumber ?? "N/A")</p>
                                                    <p><strong>Location:</strong> @(singleAsset.Location ?? "N/A")</p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <!-- Multi-select with checkboxes for better UX -->
                                    <div class="card">
                                        <div class="card-header bg-light">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <span>Available Assets (@availableAssets.Count)</span>
                                                <div>
                                                    <button type="button" class="btn btn-sm btn-outline-primary" id="selectAll">
                                                        <i class="fas fa-check-square"></i> Select All
                                                    </button>
                                                    <button type="button" class="btn btn-sm btn-outline-secondary" id="deselectAll">
                                                        <i class="fas fa-square"></i> Clear All
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="card-body" style="max-height: 400px; overflow-y: auto;">
                                            <div class="row g-2">
                                                @foreach (var asset in availableAssets)
                                                {
                                                    <div class="col-md-6">
                                                        <div class="form-check asset-checkbox-item p-3 border rounded">
                                                            <input class="form-check-input asset-checkbox" 
                                                                   type="checkbox" 
                                                                   name="assetIds" 
                                                                   value="@asset.Id" 
                                                                   id="asset_@asset.Id">
                                                            <label class="form-check-label w-100" for="asset_@asset.Id" style="cursor: pointer;">
                                                                <div class="d-flex justify-content-between">
                                                                    <strong>@asset.AssetTag</strong>
                                                                    <span class="badge bg-primary">@asset.Category</span>
                                                                </div>
                                                                <div class="text-muted small">
                                                                    @asset.Brand @asset.Model
                                                                </div>
                                                                <div class="text-muted small">
                                                                    <i class="fas fa-map-marker-alt"></i> @(asset.Location ?? "N/A")
                                                                </div>
                                                            </label>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                        <div class="card-footer bg-light">
                                            <div id="selectedCount" class="text-center">
                                                <i class="fas fa-info-circle"></i> Please select at least one asset
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>

                            <!-- Justification -->
                            <div class="mb-3">
                                <label for="justification" class="form-label">
                                    <i class="fas fa-comment-dots"></i> Justification <span class="text-danger">*</span>
                                </label>
                                <textarea class="form-control" id="justification" name="justification"
                                          rows="4" required maxlength="500"
                                          placeholder="Please provide a reason for requesting @(singleAsset != null ? "this asset" : "these assets")..."></textarea>
                                <div class="form-text">Required - Explain why you need @(singleAsset != null ? "this asset" : "these assets") (max 500 characters)</div>
                            </div>

                            <!-- Expected Return Date -->
                            <div class="mb-4">
                                <label for="expectedReturnDate" class="form-label">
                                    <i class="fas fa-calendar-alt"></i> Expected Return Date <span class="text-danger">*</span>
                                </label>
                                <input type="date" class="form-control" id="expectedReturnDate"
                                       name="expectedReturnDate" required
                                       min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")" />
                                <div class="form-text">Required - When do you expect to return @(singleAsset != null ? "this asset" : "these assets")?</div>
                            </div>

                            <div class="alert alert-info">
                                <i class="fas fa-info-circle"></i> <strong>Note:</strong> Your request will be sent to the approval team for review.
                                You will be notified once it has been approved or rejected.
                            </div>

                            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                                <a asp-action="Index" class="btn btn-secondary">
                                    <i class="fas fa-times"></i> Cancel
                                </a>
                                <button type="submit" class="btn btn-success">
                                    <i class="fas fa-paper-plane"></i> Submit Request
                                </button>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    
    @if (singleAsset == null)
    {
        <script>
            // Handle checkbox selection
            const checkboxes = document.querySelectorAll('.asset-checkbox');
            const selectAllBtn = document.getElementById('selectAll');
            const deselectAllBtn = document.getElementById('deselectAll');
            const countDiv = document.getElementById('selectedCount');
            const form = document.getElementById('requestForm');

            function updateSelectedCount() {
                const selected = document.querySelectorAll('.asset-checkbox:checked').length;
                if (selected > 0) {
                    countDiv.innerHTML = `<i class="fas fa-check-circle text-success"></i> <strong>${selected} asset(s) selected</strong>`;
                    countDiv.classList.remove('text-danger');
                    countDiv.classList.add('text-success');
                } else {
                    countDiv.innerHTML = '<i class="fas fa-info-circle text-danger"></i> <strong>Please select at least one asset</strong>';
                    countDiv.classList.remove('text-success');
                    countDiv.classList.add('text-danger');
                }
            }

            // Update count on checkbox change
            checkboxes.forEach(checkbox => {
                checkbox.addEventListener('change', function() {
                    // Highlight selected items
                    const parent = this.closest('.asset-checkbox-item');
                    if (this.checked) {
                        parent.classList.add('border-success', 'bg-light');
                    } else {
                        parent.classList.remove('border-success', 'bg-light');
                    }
                    updateSelectedCount();
                });
            });

            // Select All button
            selectAllBtn.addEventListener('click', function() {
                checkboxes.forEach(cb => {
                    cb.checked = true;
                    cb.closest('.asset-checkbox-item').classList.add('border-success', 'bg-light');
                });
                updateSelectedCount();
            });

            // Deselect All button
            deselectAllBtn.addEventListener('click', function() {
                checkboxes.forEach(cb => {
                    cb.checked = false;
                    cb.closest('.asset-checkbox-item').classList.remove('border-success', 'bg-light');
                });
                updateSelectedCount();
            });

            // Form validation
            form.addEventListener('submit', function(e) {
                const selected = document.querySelectorAll('.asset-checkbox:checked').length;
                if (selected === 0) {
                    e.preventDefault();
                    alert('Please select at least one asset before submitting the request.');
                    countDiv.innerHTML = '<i class="fas fa-exclamation-triangle text-danger"></i> <strong>Please select at least one asset</strong>';
                    return false;
                }
            });

            // Initialize count on page load
            updateSelectedCount();
        </script>

        <style>
            .asset-checkbox-item {
                transition: all 0.2s ease;
            }
            .asset-checkbox-item:hover {
                background-color: #f8f9fa;
                border-color: #0d6efd !important;
            }
            .form-check-input:checked + .form-check-label {
                font-weight: 500;
            }
        </style>
    }
}
