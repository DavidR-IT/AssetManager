@model Asset
@{
    ViewData["Title"] = "Edit Asset";
}

<div class="container mt-4">
    <h2>Edit Asset</h2>
    <hr />

    <div class="row">
        <div class="col-md-8">
            <form method="post" asp-action="Edit">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="AssetTag" class="form-label"></label>
                    <input asp-for="AssetTag" class="form-control" />
                    <span asp-validation-for="AssetTag" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Category" class="form-label"></label>
                    <select asp-for="Category" class="form-select">
                        <option value="">-- Select Category --</option>
                        <option value="Laptop">Laptop</option>
                        <option value="Desktop">Desktop</option>
                        <option value="Monitor">Monitor</option>
                        <option value="Printer">Printer</option>
                        <option value="Phone">Phone</option>
                        <option value="Accessories">Accessories</option>
                        <option value="Other">Other</option>
                    </select>
                    <span asp-validation-for="Category" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Brand" class="form-label"></label>
                        <select asp-for="Brand" class="form-select">
                            <option value="">-- Select Brand --</option>
                            <option value="Dell">Dell</option>
                            <option value="HP">HP</option>
                            <option value="Lenovo">Lenovo</option>
                            <option value="Asus">Asus</option>
                            <option value="Acer">Acer</option>
                            <option value="Samsung">Samsung</option>
                            <option value="Other">Other</option>
                        </select>
                        <span asp-validation-for="Brand" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Model" class="form-label"></label>
                        <input asp-for="Model" class="form-control" list="modelList" />
                        <datalist id="modelList">
                            <option value="Latitude 5520" />
                            <option value="Latitude 7420" />
                            <option value="ThinkPad X1 Carbon" />
                            <option value="ThinkPad T14" />
                            <option value="MacBook Pro 14" />
                            <option value="MacBook Pro 16" />
                            <option value="MacBook Air M2" />
                            <option value="EliteBook 840" />
                            <option value="ProBook 450" />
                            <option value="Surface Laptop 5" />
                            <option value="Surface Pro 9" />
                            <option value="VivoBook 15" />
                            <option value="ROG Strix" />
                            <option value="Aspire 5" />
                            <option value="Predator Helios" />
                            <option value="Galaxy Book3" />
                            <option value="IdeaPad 3" />
                        </datalist>
                        <span asp-validation-for="Model" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="SerialNumber" class="form-label"></label>
                    <input asp-for="SerialNumber" class="form-control" />
                    <span asp-validation-for="SerialNumber" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" class="form-select">
                        <option value="@((int)AssetStatus.Ready)">Ready</option>
                        <option value="@((int)AssetStatus.Maintenance)">Maintenance</option>
                        <option value="@((int)AssetStatus.Retired)">Retired</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                    <small class="form-text text-muted">Admin manages Ready/Maintenance/Retired. Pending/Assigned are set automatically by the system.</small>
                </div>

                <div class="mb-3">
                    <label asp-for="Location" class="form-label"></label>
                    <select asp-for="Location" class="form-select">
                        <option value="">-- Select Location --</option>
                        <option value="Lot 60/61 Ogle">Lot 60/61 Ogle</option>
                        <option value="Lot 16 Ogle">Lot 16 Ogle</option>
                        <option value="Other">Other</option>
                    </select>
                    <span asp-validation-for="Location" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="PurchaseDate" class="form-label"></label>
                        <input asp-for="PurchaseDate" class="form-control" type="date" />
                        <span asp-validation-for="PurchaseDate" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="PurchasePrice" class="form-label"></label>
                        <input asp-for="PurchasePrice" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="PurchasePrice" class="text-danger"></span>
                    </div>
                </div>

                @if (ViewBag.Users != null && ((List<User>)ViewBag.Users).Any())
                {
                    <div class="mb-3">
                        <label asp-for="AssignedTo" class="form-label"></label>
                        <select asp-for="AssignedTo" class="form-select" id="assignedToSelect">
                            <option value="">-- Not Assigned --</option>
                            @foreach (var user in (List<User>)ViewBag.Users)
                            {
                                <option value="@user.Email">@user.Email (@user.Role)</option>
                            }
                        </select>
                        <span asp-validation-for="AssignedTo" class="text-danger"></span>
                        <small class="form-text text-muted">Select a user to assign this asset to, or leave empty if not assigned.</small>
                    </div>
                }
                else
                {
                    <div class="mb-3">
                        <label asp-for="AssignedTo" class="form-label"></label>
                        <input asp-for="AssignedTo" class="form-control" />
                        <span asp-validation-for="AssignedTo" class="text-danger"></span>
                        <small class="form-text text-muted">Leave empty if not assigned to anyone.</small>
                    </div>
                }

                <div class="mb-3">
                    <label asp-for="AssignedDate" class="form-label"></label>
                    <input asp-for="AssignedDate" class="form-control" type="datetime-local" />
                    <span asp-validation-for="AssignedDate" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Notes" class="form-label"></label>
                    <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Notes" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Save Changes
                    </button>
                    <a class="btn btn-secondary" asp-action="Index">
                        <i class="fas fa-times"></i> Cancel
                    </a>
                </div>
            </form>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5>Asset Information</h5>
                </div>
                <div class="card-body">
                    <p><strong>Asset ID:</strong> @Model.Id</p>
                    <p><strong>Current Status:</strong> <span class="badge bg-@GetStatusColor(Model.Status)">@Model.Status</span></p>
                    @if (!string.IsNullOrEmpty(Model.AssignedTo))
                    {
                        <p><strong>Currently Assigned To:</strong> @Model.AssignedTo</p>
                        @if (Model.AssignedDate.HasValue)
                        {
                            <p><strong>Assigned Since:</strong> @Model.AssignedDate.Value.ToString("yyyy-MM-dd")</p>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{  
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

@functions {
    private string GetStatusColor(AssetStatus status)
    {
        return status switch
        {
            AssetStatus.Ready => "success",
            AssetStatus.Pending => "warning",
            AssetStatus.Assigned => "info",
            AssetStatus.Maintenance => "secondary",
            AssetStatus.Retired => "danger",
            _ => "light"
        };
    }
}
