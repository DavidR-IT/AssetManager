@model IEnumerable<AssetManager.Models.AssetRequest>
@{
    ViewData["Title"] = "My Requests";
}

<div class="container mt-4">
    <h2>My Asset Requests</h2>
    <p class="text-muted">View all your asset requests and their current status</p>
    <hr />

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> You haven't made any asset requests yet.
            <a asp-action="Index" class="alert-link">Browse available assets</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Request ID</th>
                        <th>Asset(s)</th>
                        <th>Category</th>
                        <th>Brand/Model</th>
                        <th>Request Type</th>
                        <th>Status</th>
                        <th>Request Date</th>
                        <th>Approved By</th>
                        <th>Approval Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var request in Model)
                    {
                        <tr>
                            <td>@request.Id</td>

                            @* Asset(s) Column - Show badge for multi-asset, tag for single *@
                            <td>
                                @if (request.RequestedAssets != null && request.RequestedAssets.Any())
                                {
                                    <span class="badge bg-primary">
                                        <i class="fas fa-layer-group"></i> @request.RequestedAssets.Count asset(s)
                                    </span>
                                }
                                else
                                {
                                    @(request.Asset?.AssetTag ?? "N/A")
                                }
                            </td>

                            @* Category Column *@
                            <td>
                                @if (request.RequestedAssets != null && request.RequestedAssets.Any())
                                {
                                    <span class="text-muted">Multiple</span>
                                }
                                else
                                {
                                    @(request.Asset?.Category ?? "N/A")
                                }
                            </td>

                            @* Brand/Model Column *@
                            <td>
                                @if (request.RequestedAssets != null && request.RequestedAssets.Any())
                                {
                                    <span class="text-muted">Various</span>
                                }
                                else
                                {
                                    @(request.Asset?.Brand ?? "N/A") @(request.Asset?.Model ?? "")
                                }
                            </td>

                            <td>
                                <span class="badge bg-@(request.RequestType == RequestTypes.Issue ? "primary" : request.RequestType == RequestTypes.Request ? "success" : "info")">
                                    @request.RequestType
                                </span>
                            </td>
                            <td>
                                @if (request.Status == RequestStatuses.Pending)
                                {
                                    <span class="badge bg-warning text-dark">@request.Status</span>
                                }
                                else if (request.Status == RequestStatuses.Approved)
                                {
                                    <span class="badge bg-success">@request.Status</span>
                                }
                                else if (request.Status == RequestStatuses.Rejected)
                                {
                                    <span class="badge bg-danger">@request.Status</span>
                                }
                                else if (request.Status == RequestStatuses.Cancelled)
                                {
                                    <span class="badge bg-secondary">@request.Status</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-dark">@request.Status</span>
                                }
                            </td>
                            <td>@request.RequestDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(request.ApprovedBy ?? "-")</td>
                            <td>@(request.ApprovalDate?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                            <td>
                                @* View Details button - works for both single and multi-asset requests *@
                                <a class="btn btn-sm btn-info" asp-controller="Requests" asp-action="Details" asp-route-id="@request.Id" title="View Request Details">
                                    <i class="fas fa-eye"></i> View
                                </a>

                                @* Cancel button for pending requests *@
                                @if (request.Status == RequestStatuses.Pending)
                                {
                                    <form asp-controller="Requests" asp-action="Cancel" asp-route-id="@request.Id"
                                          method="post" style="display: inline;"
                                          onsubmit="return confirm('Are you sure you want to cancel this request?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger" title="Cancel Request">
                                            <i class="fas fa-times"></i> Cancel
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-3">
            <p class="text-muted">
                <strong>Pending:</strong> @Model.Count(r => r.Status == RequestStatuses.Pending) |
                <strong>Approved:</strong> @Model.Count(r => r.Status == RequestStatuses.Approved) |
                <strong>Rejected:</strong> @Model.Count(r => r.Status == RequestStatuses.Rejected) |
                <strong>Cancelled:</strong> @Model.Count(r => r.Status == RequestStatuses.Cancelled)
            </p>
        </div>
    }

    <div class="mt-3">
        <a class="btn btn-secondary" asp-action="Index">
            <i class="fas fa-arrow-left"></i> Back to Assets
        </a>
    </div>
</div>
