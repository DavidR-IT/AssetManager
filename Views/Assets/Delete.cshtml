@model Asset
@{
    ViewData["Title"] = "Delete Asset";
}
<div class="container mt-4">
    <h2 class="text-danger">Delete Asset</h2>
    <hr />
    <div class="alert alert-danger" role="alert">
        <h4 class="alert-heading">Warning!</h4>
        <p>Are you sure you want to delete this asset? This action cannot be undone.</p>
    </div>
    <dl class="row">
        <dt class="col-sm-3">Asset Tag</dt>
        <dd class="col-sm-9">@Model.AssetTag</dd>
        <dt class="col-sm-3">Category</dt>
        <dd class="col-sm-9">@Model.Category</dd>
        <dt class="col-sm-3">Brand</dt>
        <dd class="col-sm-9">@Model.Brand</dd>
        <dt class="col-sm-3">Model</dt>
        <dd class="col-sm-9">@Model.Model</dd>
        <dt class="col-sm-3">Serial Number</dt>
        <dd class="col-sm-9">@Model.SerialNumber</dd>
        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">
            <span class="badge bg-@GetStatusColor(Model.Status)">@Model.Status</span>
        </dd>
        <dt class="col-sm-3">Assigned To</dt>
        <dd class="col-sm-9">@(Model.AssignedTo ?? "Not Assigned")</dd>
        <dt class="col-sm-3">Location</dt>
        <dd class="col-sm-9">@Model.Location</dd>
        <dt class="col-sm-3">Purchase Date</dt>
        <dd class="col-sm-9">@(Model.PurchaseDate?.ToString("yyyy-MM-dd") ?? "N/A")</dd>
        <dt class="col-sm-3">Purchase Price</dt>
        <dd class="col-sm-9">@(Model.PurchasePrice?.ToString("C") ?? "N/A")</dd>
        @if (!string.IsNullOrWhiteSpace(Model.Notes))
        {
            <dt class="col-sm-3">Notes</dt>
            <dd class="col-sm-9">@Model.Notes</dd>
        }
    </dl>
    <form method="post" asp-action="Delete" asp-route-id="@Model.Id">
        @Html.AntiForgeryToken()
        <div class="form-group">
            <button type="submit" class="btn btn-danger" onclick="return confirm('Are you absolutely sure you want to delete this asset?');">
                <i class="fas fa-trash"></i> Delete Asset
            </button>
            <a class="btn btn-secondary" asp-action="Index">
                <i class="fas fa-times"></i> Cancel
            </a>
        </div>
    </form>
</div>
@functions {
    private string GetStatusColor(AssetStatus status)
    {
        return status switch
        {
            AssetStatus.Ready => "success",
            AssetStatus.Pending => "warning",
            AssetStatus.Assigned => "info",
            AssetStatus.Maintenance => "secondary",
            AssetStatus.Retired => "danger",
            _ => "light"
        };
    }
}
