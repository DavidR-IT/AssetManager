@model AssetManager.Models.ViewModels.UserViewModel

@{
    ViewData["Title"] = "Delete User";
    var assignedAssetsCount = ViewBag.AssignedAssetsCount as int? ?? 0;
    var pendingRequestsCount = ViewBag.PendingRequestsCount as int? ?? 0;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="alert alert-danger" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <strong>Warning!</strong> This action cannot be undone.
            </div>

            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-trash"></i> Delete User Confirmation
                    </h4>
                </div>
                <div class="card-body">
                    <p class="lead">Are you sure you want to delete this user?</p>

                    <div class="card mb-4 bg-light">
                        <div class="card-body">
                            <h5 class="card-title">@Model.Email</h5>
                            <p class="text-muted mb-0">User ID: @Model.Id</p>
                        </div>
                    </div>

                    <!-- User Details -->
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h6 class="fw-bold text-muted">Roles</h6>
                            @if (Model.Roles.Any())
                            {
                                @foreach (var role in Model.Roles)
                                {
                                    <span class="badge bg-warning text-dark">@role</span>
                                }
                            }
                            else
                            {
                                <span class="badge bg-secondary">No Roles</span>
                            }
                        </div>
                        <div class="col-md-6">
                            <h6 class="fw-bold text-muted">Assigned Assets</h6>
                            <span class="badge bg-info" style="font-size: 1rem;">@assignedAssetsCount Assets</span>
                        </div>
                    </div>

                    <!-- Assets Warning -->
                    @if (assignedAssetsCount > 0)
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-info-circle"></i>
                            <strong>Note:</strong> This user has @assignedAssetsCount assigned asset(s).
                            <br />
                            <small>These assets will be unassigned and returned to available status when the user is deleted.</small>
                        </div>
                    }

                    <!-- Pending Requests Warning -->
                    @if (pendingRequestsCount > 0)
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i>
                            <strong>Note:</strong> This user has @pendingRequestsCount pending request(s).
                            <br />
                            <small>These requests will be cancelled when the user is deleted.</small>
                        </div>
                    }

                    <!-- Consequences -->
                    <div class="alert alert-info">
                        <strong><i class="bi bi-exclamation-circle"></i> This will:</strong>
                        <ul class="mb-0 mt-2">
                            <li>Permanently delete the user account</li>
                            @if (assignedAssetsCount > 0)
                            {
                                <li>Return @assignedAssetsCount assigned asset(s) to Ready status</li>
                            }
                            @if (pendingRequestsCount > 0)
                            {
                                <li>Cancel @pendingRequestsCount pending request(s) and revert those assets to Ready</li>
                            }
                            <li>Preserve all request history for auditing (requests will remain but show no linked user)</li>
                            <li>This action cannot be reversed</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="mt-4 d-flex gap-2">
                <form asp-action="Delete" method="post" class="d-inline">
                    <input type="hidden" name="id" value="@Model.Id" />
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger btn-lg" onclick="return confirm('Are you absolutely sure you want to delete this user?');">
                        <i class="bi bi-check-circle"></i> Yes, Delete User
                    </button>
                </form>
                <a asp-action="Index" class="btn btn-secondary btn-lg">
                    <i class="bi bi-x-circle"></i> Cancel
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        border-radius: 0.5rem;
    }

    .card-header {
        font-weight: 600;
    }

    .alert {
        border-left: 4px solid;
    }

    .alert-danger {
        border-left-color: #dc3545;
    }

    .alert-warning {
        border-left-color: #ffc107;
    }

    .alert-info {
        border-left-color: #0dcaf0;
    }
</style>
